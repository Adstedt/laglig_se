{
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/cleanup-workspaces",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/retry-failed-pdfs",
      "schedule": "0 6 * * 0"
    },
    {
      "path": "/api/cron/notify-amendment-changes",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/discover-sfs-amendments",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/discover-sfs-amendments",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/discover-sfs-amendments",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/discover-sfs-amendments",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/sync-sfs-updates",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/sync-sfs",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/prewarm-cache",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/warm-cache",
      "schedule": "15 17 * * *"
    },
    {
      "path": "/api/cron/notify-task-deadlines",
      "schedule": "10 7 * * *"
    },
    {
      "path": "/api/cron/notify-weekly-digest",
      "schedule": "0 16 * * 0"
    },
    {
      "path": "/api/cron/daily-ops-digest",
      "schedule": "0 21 * * *"
    }
  ]
}
