// ============================================================================
// EPIC 17: DOCUMENT MANAGEMENT SYSTEM
// WorkspaceDocument* models — prefixed to avoid collision with existing
// DocumentVersion/DocumentStatus used by LegalDocument/SFS system
// ============================================================================

enum WorkspaceDocumentType {
  POLICY
  RISK_ASSESSMENT
  ACTION_PLAN
  PROCEDURE
  INSTRUCTION
  CHECKLIST
  REPORT
  OTHER
}

enum WorkspaceDocumentStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  SUPERSEDED
  ARCHIVED
}

enum WorkspaceDocumentVersionSource {
  TIPTAP
  IMPORT
  AGENT
}

model WorkspaceDocument {
  id              String                  @id @default(uuid())
  workspace_id    String
  title           String
  document_type   WorkspaceDocumentType   @default(OTHER)
  status          WorkspaceDocumentStatus @default(DRAFT)
  document_number String?

  // Version tracking
  current_version_id     String? @unique
  current_version_number Int     @default(0)

  // Template reference
  template_id String?

  // Lifecycle / compliance
  approved_by     String?
  approved_at     DateTime?
  review_date     DateTime?
  retention_until DateTime?

  // Ownership
  created_by String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Story 17.10b: cron-sweep debounce flags for DRAFT autosave reindex.
  // `autosaveDocument` flips needs_reindex = true + records last_marked_dirty_at;
  // /api/cron/sweep-draft-reindex picks rows where the dirty-mark has aged past
  // DRAFT_REINDEX_DEBOUNCE_MS (60s) and clears the flag after indexing.
  needs_reindex        Boolean   @default(false)
  last_marked_dirty_at DateTime?

  // Relations
  workspace       Workspace                       @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  creator         User                            @relation("WsDocCreator", fields: [created_by], references: [id])
  approver        User?                           @relation("WsDocApprover", fields: [approved_by], references: [id])
  current_version WorkspaceDocumentVersion?       @relation("WorkspaceDocumentCurrentVersion", fields: [current_version_id], references: [id])
  versions        WorkspaceDocumentVersion[]      @relation("WorkspaceDocumentVersions")
  template        WorkspaceDocumentTemplate?      @relation(fields: [template_id], references: [id])
  task_links      WorkspaceDocumentTaskLink[]
  list_item_links WorkspaceDocumentListItemLink[]

  // Story 17.16: Kravpunkter evidence links
  requirement_evidence_links RequirementEvidenceLink[]

  @@index([workspace_id, status])
  @@index([workspace_id, document_type])
  @@index([workspace_id, created_at])
  // Story 17.10b: partial-like index for the cron sweep (Postgres will use the
  // composite index when scanning for needs_reindex = true).
  @@index([needs_reindex, last_marked_dirty_at])
  @@map("workspace_documents")
}

model WorkspaceDocumentVersion {
  id             String                         @id @default(uuid())
  document_id    String
  version_number Int
  source         WorkspaceDocumentVersionSource @default(TIPTAP)

  // Content (Tiptap JSON is source of truth)
  content_json   Json
  content_html   String  @db.Text
  extracted_text String? @db.Text

  // Import source file
  storage_path String?

  // Change tracking
  change_summary String?
  created_by     String // User ID or "agent" — no FK, resolve display at query time
  created_at     DateTime @default(now())

  // Relations
  document    WorkspaceDocument  @relation("WorkspaceDocumentVersions", fields: [document_id], references: [id], onDelete: Cascade)
  current_for WorkspaceDocument? @relation("WorkspaceDocumentCurrentVersion")

  @@unique([document_id, version_number])
  @@index([document_id, created_at])
  @@map("workspace_document_versions")
}

model WorkspaceDocumentTemplate {
  id            String                @id @default(uuid())
  name          String
  description   String?
  document_type WorkspaceDocumentType
  content_json  Json
  is_active     Boolean               @default(true)
  sort_order    Int                   @default(0)
  created_at    DateTime              @default(now())
  updated_at    DateTime              @updatedAt

  documents WorkspaceDocument[]

  @@map("workspace_document_templates")
}

model WorkspaceDocumentTaskLink {
  id          String   @id @default(uuid())
