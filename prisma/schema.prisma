// ============================================================================
// AI CHAT MESSAGES - Epic 3: Story 3.3
// Chat history persistence for AI conversations
// ============================================================================

model ChatMessage {
  id              String          @id @default(uuid())
  workspace_id    String
  user_id         String
  role            ChatMessageRole
  content         String          @db.Text
  metadata        Json? // Citation sources, tool results, etc.
  context_type    ChatContextType @default(GLOBAL)
  context_id      String? // References task_id or law_list_item_id depending on context_type
  conversation_id String? // Groups messages into conversations; null = active conversation
  created_at      DateTime        @default(now())

  // Relations
  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Story 14.22: Agent approval cards anchored to the assistant message that proposed them
  pending_agent_actions PendingAgentAction[]

  @@index([workspace_id, user_id, context_type, context_id])
  @@index([workspace_id, user_id, created_at])
  @@index([conversation_id])
  @@map("chat_messages")
}

enum ChatMessageRole {
  USER
  ASSISTANT
}

enum ChatContextType {
  GLOBAL
  TASK
  LAW
  CHANGE
  // Story 24.3 — per-row LLM telemetry for the import-pipeline matcher.
  // Distinguishes matcher cost from chat cost in the admin usage dashboard.
  IMPORT_MATCHING
  // Story 24.7 — per-call LLM telemetry for the granska-page grouping
  // proposer (claude-haiku-4-5). Distinguishes grouping cost from matching.
  IMPORT_GROUPING
  // Story 17.8 — per-file LLM telemetry for the uploaded-file extraction
  // pipeline (PDF→Claude Haiku). Distinguishes ingestion cost from chat/import.
  FILE_EXTRACTION
}

// Story 14.27: Per-turn chat usage telemetry. One row per successful chat turn.
// Fail-safe write — errors in onFinish callback are logged but never re-thrown.
// Failed/rate-limited turns do NOT produce rows (missing data preferred over misleading data).
model ChatUsageEvent {
  id           String          @id @default(uuid())
  workspace_id String
  user_id      String
  model        String // e.g., "claude-sonnet-4-6", "gpt-4-turbo"
  context_type ChatContextType

  // Token dimensions — all non-negative; default 0 for model-path-absent fields
  input_tokens             Int @default(0)
  output_tokens            Int @default(0)
  cache_read_input_tokens  Int @default(0) // Anthropic-only when > 0
  cache_write_input_tokens Int @default(0) // Anthropic-only when > 0
  reasoning_tokens         Int @default(0) // Story 14.20 thinking output; Anthropic-only

  // Agentic loop depth — 1 for single-call turns, 2+ for tool-using turns
  step_count Int @default(1)

  // USD cost estimate computed at write time. Stored (not computed on read) for
  // fast aggregation. Recomputable from tokens + model via lib/usage/cost-estimator.
  cost_usd_estimate Decimal @db.Decimal(10, 6)

  created_at DateTime @default(now())

  // Relations
  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([workspace_id, created_at])
  @@index([user_id, created_at])
  @@index([workspace_id, user_id, created_at])
  @@index([context_type, created_at])
  @@map("chat_usage_events")
}

// ============================================================================
// AGENT APPROVAL CARDS — Story 14.22
// Persistent, inline agent action proposals (replaces the ephemeral sidebar
// write-preview pattern). Workspace-scoped. chat_message_id is non-null: the FK
// target is guaranteed by the pre-loop stub ChatMessage written in
// app/api/chat/route.ts before the tool loop (see ADR-14.22-A). expires_at is
// application-set to now()+7d at creation time (no DB default for now()+interval).
// ============================================================================
model PendingAgentAction {
  id              String                   @id @default(uuid())
  workspace_id    String
  user_id         String
  conversation_id String? // null = active conversation
  chat_message_id String // FK to the assistant ChatMessage that proposed this action
  context_type    ChatContextType          @default(GLOBAL)
  context_id      String? // task_id or law_list_item_id depending on context_type
  action_type     PendingAgentActionType
  status          PendingAgentActionStatus @default(PENDING)
  params          Json // editable snapshot of proposal parameters
  result_ref      Json? // e.g. { taskId } after approve
  created_at      DateTime                 @default(now())
  decided_at      DateTime?
  expires_at      DateTime // application-set to now()+7d at creation

  // Relations
  workspace    Workspace   @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  chat_message ChatMessage @relation(fields: [chat_message_id], references: [id], onDelete: Cascade)

  @@index([workspace_id, user_id, conversation_id, status], map: "pending_agent_actions_scope_idx")
  @@index([chat_message_id])
  @@index([expires_at])
  @@map("pending_agent_actions")
}

enum PendingAgentActionType {
  CREATE_TASK
  // Story 14.23 — extended approval types (4 new) + the two migrated sidebar
  // write-preview tools (ADD_CONTEXT_NOTE, UPDATE_COMPLIANCE_STATUS). Additive
  // enum-value additions only; ordered alphabetically after CREATE_TASK.
  ADD_CONTEXT_NOTE
  ADD_OBLIGATION
  ASSIGN_TASK
  LINK_DOCUMENT_TO_TASK
  LINK_TASK_TO_DOCUMENT
  UPDATE_COMPLIANCE_STATUS
  // Story 14.28 — agent-proposed kravpunkt (requirement) edit. Additive enum-value addition.
  UPDATE_REQUIREMENT
  // Story 14.24 — agent-drafted styrdokument approval. Additive enum-value addition.
  DRAFT_DOCUMENT
  // Story 14.29 — agent-proposed task comment approval (append-only; no diff,
  // no editor path). Dispatch calls the existing createComment server action.
  // Additive enum-value addition.
  ADD_TASK_COMMENT
  // Story 14.30 — agent-proposed styrdokument status transition. Separation-of-
  // duties: agent never proposes APPROVED (guarded at the tool AND the dispatch
  // as defence-in-depth). Dispatch calls the existing updateDocumentStatus
  // server action. Additive enum-value addition.
  TRANSITION_DOCUMENT_STATUS
  // Story 17.11 — agent-proposed section-level edit to an existing workspace
  // document. Approval-gated (no execute:true path). Dispatch calls the
  // existing saveDocumentVersion server action with the full updated
  // contentJson produced by updateSection(). DRAFT/IN_REVIEW only; APPROVED
  // documents must branch via createDraftFromApproved first. Additive
  // enum-value addition.
  UPDATE_DOCUMENT
  // Story 17.11b — agent-proposed insert of a NEW section into an existing
  // workspace document. Approval-gated (mirrors UPDATE_DOCUMENT pattern). On
  // approval dispatch calls addSection() to produce the full updated
  // contentJson, then saveDocumentVersion appends a new version + reindexes.
  // DRAFT/IN_REVIEW only; no-duplicate-heading + position-target-exists guards
  // at both tool time AND dispatch. Additive enum-value addition.
  ADD_DOCUMENT_SECTION
}

enum PendingAgentActionStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  // Story 14.24 — draft document opened in the Tiptap editor, awaiting finalize/reject.
  IN_EDITOR
}

// ============================================================================
// AGENT DECISION LOG — Story 19.5
// One row per agent tool invocation (reads, write proposals, failures) — the
// audit trail complementing PendingAgentAction's proposal lifecycle. The soft
// refs (chat_message_id, pending_action_id, accepted_by) are plain columns, NOT
// FKs: an audit log is intentionally decoupled + durable (survives deletion of
// the message/proposal/approver it references). workspace_id + user_id ARE FK
// Cascade (a deleted workspace/user takes its logs with it — matches
// ChatUsageEvent). Written fail-safe: a log error never breaks the tool call.
// ============================================================================
model AgentDecisionLog {
  id                String               @id @default(uuid())
  workspace_id      String
  user_id           String
  chat_message_id   String? // soft ref — null outside a chat turn (future cron/CLI)
  pending_action_id String? // soft ref — set only for write proposals; exact approve/reject match key (Story 19.5 SF-1)
  tool_name         String // free-form; String not enum so new tools ship without a migration
  input_json        Json
  output_json       Json? // null if execute threw before returning a result
  proposed_at       DateTime             @default(now()) // wrapper-entry time
  accepted_at       DateTime?
  accepted_by       String? // soft ref — approver user id
  outcome           AgentDecisionOutcome
  model_version     String
  created_at        DateTime             @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([workspace_id, created_at])
  @@index([workspace_id, user_id, created_at])
  @@index([tool_name, created_at])
  @@index([chat_message_id])
  @@index([pending_action_id])
  @@map("agent_decision_logs")
}

enum AgentDecisionOutcome {
  SUCCESS // tool executed, non-write result returned
  WRITE_PROPOSED // write tool returned a PendingAgentAction proposal
  WRITE_ACCEPTED // proposal approved (accepted_at/accepted_by populated)
  WRITE_REJECTED // proposal rejected or expired
  ERROR // tool threw, or returned a ToolError envelope
}

// Story 25.0 (Epic 25): First-run onboarding modal telemetry.
// Workspace-scoped product-event log with a polymorphic JSON payload.
// event_type is a free-form string (no DB enum) so new event types ship
// without a migration — same additive philosophy as ChatUsageEvent.
// Known event_type values: 'modal_opened' | 'path_chosen' | 'tab_viewed'
// | 'modal_dismissed' | 'fab_dismissed' | 'feedback_submitted'.
model OnboardingEvent {
  id           String   @id @default(uuid())
  workspace_id String
  user_id      String
  event_type   String
  payload      Json?
  created_at   DateTime @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([workspace_id, created_at])
  @@index([event_type])
  @@map("onboarding_events")
}

