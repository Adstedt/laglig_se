  linker   User              @relation("WsDocTaskLinkUser", fields: [linked_by], references: [id])

  @@unique([document_id, task_id])
  @@map("workspace_document_task_links")
}

model WorkspaceDocumentListItemLink {
  id           String   @id @default(uuid())
  document_id  String
  list_item_id String
  linked_at    DateTime @default(now())
  linked_by    String

  document  WorkspaceDocument @relation(fields: [document_id], references: [id], onDelete: Cascade)
  list_item LawListItem       @relation(fields: [list_item_id], references: [id], onDelete: Cascade)
  linker    User              @relation("WsDocListItemLinkUser", fields: [linked_by], references: [id])

  @@unique([document_id, list_item_id])
  @@map("workspace_document_list_item_links")
}

// ============================================================================
// EPIC 21 — LAGEFTERLEVNADSKONTROLL (compliance audit cycle)
// Story 21.1: Schema foundations for cycle lifecycle, items, findings,
// evidence snapshots, and reports. Additive-only — zero existing columns
// modified except Task.compliance_finding_id (nullable back-reference).
// ============================================================================

enum AuditType {
  INTERN
  EXTERN
}

// Story 21.26 (2026-04-27) — collapsed SEAL into AVSLUTAD as terminal active
// state. AVSLUTAD now records sealed_at + sealed_by (column names retained
// for migration safety; semantically: completion).
// Story 21.27 (2026-04-28) — collapsed ARKIVERAD into AVSLUTAD too. ARKIVERAD
// had no UI transition; the only behavioral difference (locking findings)
// wasn't worth a phantom state for SMB self-audit. AVSLUTAD is now the
// only terminal active state; revertCycleToPagaende remains the escape hatch.
enum ComplianceCycleStatus {
  PLANERAD
  PAGAENDE
  AVSLUTAD
}

enum EfterlevnadsBedomning {
  UPPFYLLD
  DELVIS
  EJ_UPPFYLLD
  EJ_TILLAMPLIG
}

enum FindingType {
  AVVIKELSE
  OBSERVATION
  FORBATTRING
}

enum FindingSeverity {
  MAJOR
  MINOR
}

enum EvidenceKind {
  FILE
  DOCUMENT
}

// Story 21.26 (2026-04-27) — collapsed SEAL into AVSLUTAD; only one report kind
// remains. Kept as an enum (not removed) to preserve the column shape and
// retain a single explicit value for clarity in queries.
enum ReportKind {
  COMPLETE
}

model ComplianceAuditCycle {
  id                     String                @id @default(uuid())
  workspace_id           String
  law_list_id            String
  name                   String
  scope_definition       Json // {kind: 'all' | 'groups' | 'items', groupIds?: string[], itemIds?: string[]}
  audit_type             AuditType
  scheduled_start        DateTime
  scheduled_end          DateTime
  law_change_cutoff_date DateTime
  status                 ComplianceCycleStatus @default(PLANERAD)
  lead_auditor_user_id   String
  // Story 21.26 — populated by completeCycle (was: sealCycle). Column names
  // retained to avoid a wider migration; semantically these now record the
  // AVSLUTAD transition's timestamp + actor.
  sealed_at              DateTime?
  sealed_by_user_id      String?
  description            String?               @db.Text
  created_at             DateTime              @default(now())
  updated_at             DateTime              @updatedAt
  deleted_at             DateTime?
  created_by_user_id     String

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  law_list     LawList   @relation(fields: [law_list_id], references: [id], onDelete: Restrict)
  lead_auditor User      @relation("CycleLeadAuditor", fields: [lead_auditor_user_id], references: [id], onDelete: Restrict)
  sealed_by    User?     @relation("CycleSealedBy", fields: [sealed_by_user_id], references: [id], onDelete: SetNull)
  created_by   User      @relation("CycleCreatedBy", fields: [created_by_user_id], references: [id], onDelete: Restrict)

  items    ComplianceAuditItem[]
  findings ComplianceFinding[]
  reports  ComplianceAuditReport[]

  // Epic 21 Story 21.8: reverse of ComplianceCycleTaskLink — cycle's linked tasks.
  task_links ComplianceCycleTaskLink[]

  @@index([workspace_id, status])
  @@index([law_list_id])
  @@index([lead_auditor_user_id])
  @@map("compliance_audit_cycles")
}

model ComplianceAuditItem {
  id                    String                 @id @default(uuid())
  cycle_id              String
  law_list_item_id      String
  efterlevnadsbedomning EfterlevnadsBedomning?
  motivering            String?                @db.Text
  reviewed_at           DateTime?
  reviewed_by_user_id   String?
  signed_off_at         DateTime?
  signed_off_by_user_id String?
  kravpunkter_snapshot  Json? // Frozen copy of requirement state at materialisation time
  created_at            DateTime               @default(now())
  updated_at            DateTime               @updatedAt

  cycle         ComplianceAuditCycle @relation(fields: [cycle_id], references: [id], onDelete: Cascade)
  law_list_item LawListItem          @relation(fields: [law_list_item_id], references: [id], onDelete: Restrict)
  reviewed_by   User?                @relation("CycleItemReviewedBy", fields: [reviewed_by_user_id], references: [id], onDelete: SetNull)
  signed_off_by User?                @relation("CycleItemSignedOffBy", fields: [signed_off_by_user_id], references: [id], onDelete: SetNull)

  @@unique([cycle_id, law_list_item_id], map: "compliance_audit_items_cycle_id_law_list_item_id_key")
  @@index([cycle_id, signed_off_at])
  @@index([law_list_item_id])
  @@map("compliance_audit_items")
}

model ComplianceFinding {
  id                        String           @id @default(uuid())
  cycle_id                  String
  law_list_item_id          String?
  requirement_id            String?
  type                      FindingType
  severity                  FindingSeverity? // Required only for AVVIKELSE (enforced at Server Action level via Zod)
  title                     String
  description               String           @db.Text
  root_cause                String?          @db.Text
  corrective_action_task_id String?
  due_date                  DateTime?
  closed_at                 DateTime?
  closed_by_user_id         String?
  // Phase 2 / Epic 23 foundation — denormalised closure metadata exposed to the
  // client for badge derivation (closed-verified vs closed-plain vs closed-dismissed).
  // Activity log retains the full audit trail; these are latest-snapshot mirrors.
  // Cleared on reopenFinding so they always reflect the current closure event (if any).
  verification_note         String?          @db.Text
  close_reason              String?          @db.Text
  created_at                DateTime         @default(now())
  updated_at                DateTime         @updatedAt

  cycle                  ComplianceAuditCycle    @relation(fields: [cycle_id], references: [id], onDelete: Cascade)
  law_list_item          LawListItem?            @relation("FindingLawListItem", fields: [law_list_item_id], references: [id], onDelete: SetNull)
  requirement            LawListItemRequirement? @relation("FindingRequirement", fields: [requirement_id], references: [id], onDelete: SetNull)
  corrective_action_task Task?                   @relation("FindingCorrectiveTask", fields: [corrective_action_task_id], references: [id], onDelete: SetNull)
  closed_by              User?                   @relation("FindingClosedBy", fields: [closed_by_user_id], references: [id], onDelete: SetNull)

  // Reverse of Task.compliance_finding_id (back-reference from task → originating finding).
  // Typically 0 or 1 task per finding at the application layer (Story 21.8 wires this 1:1).
  tasks_originated_from_this Task[] @relation("TaskOriginFinding")

  @@index([cycle_id, type])
  @@index([law_list_item_id])
  @@index([requirement_id])
  @@index([corrective_action_task_id])
  @@map("compliance_findings")
}

// Story 21.26 (2026-04-27) — ComplianceEvidenceSnapshot model removed. The
// only writer was sealCycle's gather-seal-evidence path; no remaining consumers
// after SEAL collapse. Migration drops the underlying table.

model ComplianceAuditReport {
  id                String     @id @default(uuid())
  cycle_id          String
  report_kind       ReportKind
  generated_at      DateTime   @default(now())
  pdf_storage_path  String?
  html_storage_path String?
  manifest          Json // Canonical JSON manifest (cycle + items + findings + evidence)

  cycle ComplianceAuditCycle @relation(fields: [cycle_id], references: [id], onDelete: Cascade)

  // Story 21.9 CONSTRAINT-001 (QA follow-up): one row per (cycle, kind) —
  // defense-in-depth against future multi-write paths (21.12 PDF regen).
  // sealCycle's findFirst+create is now also protected by DB-level uniqueness.
  @@unique([cycle_id, report_kind])
  @@index([cycle_id, report_kind])
  @@map("compliance_audit_reports")
}

// ============================================================================
// STRIPE BILLING - Story 5.4
// ============================================================================

// Webhook idempotency: every Stripe event.id is recorded here before we mutate
// workspace state, so retries from Stripe never double-apply.
model StripeWebhookEvent {
  id              String   @id @default(uuid())
  stripe_event_id String   @unique
  event_type      String
  processed_at    DateTime @default(now())

  @@index([processed_at])
  @@map("stripe_webhook_events")
}

// ============================================================================
// USAGE TRACKING - Story 5.5c
// ============================================================================

// Denormalised counter for AI-token quota enforcement on the chat hot path.
// Updated in the same prisma.$transaction as ChatUsageEvent (Story 14.27) so
// the per-turn audit log + the running total cannot drift. Reset by the
// customer.subscription.updated Stripe webhook when current_period_end
// advances (Pattern A — per-customer billing-cycle-anchored). Defensive
// weekly safety cron catches missed webhooks.
//
// BigInt for tokens: at 18M/month for Team and potential heavy outliers,
// regular Int (max ~2.1B) is plenty headroom but BigInt is the safer choice
// once 5.5d's metered overage relaxes the 2× hard cap.
model WorkspaceUsage {
  id                      String   @id @default(uuid())
  workspace_id            String   @unique
  tokens_used_this_period BigInt   @default(0)
  storage_bytes           BigInt   @default(0) // recomputed on file upload/delete (5.5b uses live aggregate; this column is reserved for future use)
  period_started_at       DateTime @default(now())
  updated_at              DateTime @updatedAt

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@map("workspace_usage")
}

// ============================================================================
// EPIC 24: IMPORT EXISTING LAW LIST - Story 24.1 (schema + server-action skeleton)
// ============================================================================
// Lifecycle: UPLOADED -> MATCHING -> AWAITING_REVIEW -> COMMITTED | FAILED
// Subsequent stories fill in parser (24.2), matcher (24.3), review UI (24.4),
// admin queue (24.5), and /laglistor/skapa rewire (24.6).

enum ImportStatus {
  UPLOADED // file received + rows parsed; awaiting matching
  MATCHING // matcher in progress
  AWAITING_REVIEW // matching complete; user must accept/reject rows
  COMMITTED // user committed; rows written to LawList/LawListItem
  FAILED // parser or matcher hit an unrecoverable error
}

enum RowMatchStatus {
  PENDING // not yet matched
  MATCHED_HIGH // confidence >= 0.85 — auto-acceptable
  MATCHED_MEDIUM // confidence 0.5-0.85 — user must confirm
  UNMATCHED // confidence < 0.5 — no candidate met threshold
  ACCEPTED_BY_USER // user accepted matched_doc_id
  REPLACED_BY_USER // user picked a different candidate from list
  REJECTED_BY_USER // user rejected the row entirely
  CATALOG_REQUEST_PENDING // user clicked "Begär tillägg" — queued for ops
  CATALOG_REQUEST_FULFILLED // ops ingested; row auto-rematched
}

enum CatalogRequestStatus {
  PENDING
  FULFILLED
  REJECTED // ops marked as duplicate / out of scope
}

model LawListImport {
  id                    String       @id @default(uuid())
  workspace_id          String
  created_by_user_id    String
  filename              String // e.g., "notisum-export-2026.xlsx"
  source_type           String // 'xlsx' | 'csv' | 'paste'
  status                ImportStatus @default(UPLOADED)
  row_count             Int          @default(0)
  column_mapping        Json // {titel: 'col_2', sfs_nummer: 'col_1', ...}
  committed_law_list_id String?      @unique // nullable until status=COMMITTED; @unique enforces 1:1 with LawList
  error_message         String? // populated when status=FAILED
  created_at            DateTime     @default(now())
  updated_at            DateTime     @updatedAt
  committed_at          DateTime?

  workspace          Workspace          @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  created_by         User               @relation("ImportCreatedBy", fields: [created_by_user_id], references: [id], onDelete: Restrict)
  committed_law_list LawList?           @relation(fields: [committed_law_list_id], references: [id], onDelete: SetNull)
  rows               LawListImportRow[]

  @@index([workspace_id, status])
  @@index([created_by_user_id])
  @@map("law_list_imports")
}

model LawListImportRow {
  id                  String         @id @default(uuid())
  import_id           String
  row_index           Int // 0-based row order from source file
  source_titel        String?
  source_sfs_nummer   String?
  source_omrade       String?
  source_lagansvarig  String?
  source_kommentar    String?
  source_raw          Json // full raw row in case mapping wrong
  match_status        RowMatchStatus @default(PENDING)
  matched_document_id String?
  confidence_score    Float? // 0.0-1.0
  match_candidates    Json? // [{document_id, score, title}, ...]
  match_reasoning     String? // LLM rationale; null for fuzzy-only matches
  user_decided_at     DateTime?
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt

  import           LawListImport         @relation(fields: [import_id], references: [id], onDelete: Cascade)
  matched_document LegalDocument?        @relation(fields: [matched_document_id], references: [id], onDelete: SetNull)
  catalog_request  CatalogIngestRequest?

  @@index([import_id, match_status])
  @@index([matched_document_id])
  @@map("law_list_import_rows")
}

model CatalogIngestRequest {
  id                         String               @id @default(uuid())
  workspace_id               String
  import_row_id              String               @unique // explicit 1:1 — see Dev Notes "Key decisions baked in"
  requested_by_user_id       String
  handler_user_id            String? // ops user who claimed it
  fulfilled_with_document_id String? // LegalDocument.id once ingested
  admin_note                 String?
  status                     CatalogRequestStatus @default(PENDING)
  created_at                 DateTime             @default(now())
  fulfilled_at               DateTime?
  rejected_at                DateTime?

  workspace               Workspace        @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  import_row              LawListImportRow @relation(fields: [import_row_id], references: [id], onDelete: Cascade)
  requested_by            User             @relation("CatalogRequestedBy", fields: [requested_by_user_id], references: [id], onDelete: Restrict)
  handler                 User?            @relation("CatalogRequestHandler", fields: [handler_user_id], references: [id], onDelete: SetNull)
  fulfilled_with_document LegalDocument?   @relation(fields: [fulfilled_with_document_id], references: [id], onDelete: SetNull)

  @@index([workspace_id, status, created_at])
  @@index([handler_user_id])
  @@map("catalog_ingest_requests")
}
