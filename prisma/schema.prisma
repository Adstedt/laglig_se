// Prisma Schema for Laglig.se
// Database: Supabase PostgreSQL with pgvector extension

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  // Trim Prisma query-engine binaries to just (a) the local dev platform
  // and (b) Vercel's Node 20 RHEL runtime. Default behaviour bundles every
  // platform binary (linux x4 + darwin x2 + windows), inflating the
  // serverless function bundle by ~50 MB. Verified contributor in the
  // VERCEL_ANALYZE_BUILD_OUTPUT report (77 MB @prisma/client per function).
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ============================================================================
// CORE MODELS - Epic 1: Foundation
// ============================================================================

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  name           String?
  avatar_url     String?
  password_hash  String? // NULL for OAuth users (future), Supabase Auth manages passwords
  email_verified Boolean   @default(false)
  created_at     DateTime  @default(now())
  last_login_at  DateTime?

  // Relations
  workspace_members       WorkspaceMember[]     @relation("WorkspaceMemberUser")
  invited_members         WorkspaceMember[]     @relation("WorkspaceMemberInviter")
  sent_invitations        WorkspaceInvitation[] @relation("InvitationInviter")
  owned_workspaces        Workspace[]           @relation("WorkspaceOwner")
  created_law_lists       LawList[]             @relation("LawListCreator")
  added_law_list_items    LawListItem[]         @relation("LawListItemAdder")
  assigned_law_list_items LawListItem[]         @relation("LawListItemAssignee")

  // Epic 6: Compliance workflow relations
  responsible_items        LawListItem[]            @relation("LawListItemResponsible")
  assigned_tasks           Task[]                   @relation("TaskAssignee")
  created_tasks            Task[]                   @relation("TaskCreator")
  comments                 Comment[]
  uploaded_files           WorkspaceFile[]
  file_task_links          FileTaskLink[]           @relation("FileTaskLinkUser")
  file_list_item_links     FileListItemLink[]       @relation("FileListItemLinkUser")
  notifications            Notification[]
  notification_preferences NotificationPreference[]
  activity_logs            ActivityLog[]

  // Epic 3: AI Chat
  chat_messages ChatMessage[]

  // Story 14.27: Chat usage telemetry
  chat_usage_events ChatUsageEvent[]
  agent_decision_logs AgentDecisionLog[]

  // Story 14.22: Agent approval cards
  pending_agent_actions PendingAgentAction[]

  // Epic 12: Template relations
  created_templates LawListTemplate[] @relation("TemplateCreator")
  reviewed_items    TemplateItem[]    @relation("TemplateItemReviewer")

  // Story 14.10: Change assessment relations
  change_assessments     ChangeAssessment[]    @relation("ChangeAssessmentAssessor")
  compliance_status_logs ComplianceStatusLog[] @relation("ComplianceStatusLogChanger")

  // Epic 17: Document management relations
  workspace_documents_created   WorkspaceDocument[]             @relation("WsDocCreator")
  workspace_documents_approved  WorkspaceDocument[]             @relation("WsDocApprover")
  workspace_doc_task_links      WorkspaceDocumentTaskLink[]     @relation("WsDocTaskLinkUser")
  workspace_doc_list_item_links WorkspaceDocumentListItemLink[] @relation("WsDocListItemLinkUser")

  // Story 17.16: Kravpunkter relations
  created_requirements       LawListItemRequirement[]  @relation("RequirementCreator")
  requirement_evidence_links RequirementEvidenceLink[] @relation("RequirementEvidenceLinkUser")

  // Story 20.1: Per-krav assignee
  requirements_responsible_for LawListItemRequirement[] @relation("RequirementResponsible")

  // Epic 21: Lagefterlevnadskontroll relations
  led_audit_cycles       ComplianceAuditCycle[] @relation("CycleLeadAuditor")
  sealed_audit_cycles    ComplianceAuditCycle[] @relation("CycleSealedBy")
  created_audit_cycles   ComplianceAuditCycle[] @relation("CycleCreatedBy")
  reviewed_audit_items   ComplianceAuditItem[]  @relation("CycleItemReviewedBy")
  signed_off_audit_items ComplianceAuditItem[]  @relation("CycleItemSignedOffBy")
  closed_findings        ComplianceFinding[]    @relation("FindingClosedBy")

  // Epic 24: Import existing law list
  imports_created          LawListImport[]        @relation("ImportCreatedBy")
  catalog_requests_made    CatalogIngestRequest[] @relation("CatalogRequestedBy")
  catalog_requests_handled CatalogIngestRequest[] @relation("CatalogRequestHandler")

  // Story 25.0 (Epic 25): First-run onboarding modal telemetry
  onboarding_events OnboardingEvent[]

  @@index([email])
  @@map("users")
}

model Workspace {
  id       String @id @default(uuid())
  name     String
  slug     String @unique
  owner_id String
  owner    User   @relation("WorkspaceOwner", fields: [owner_id], references: [id], onDelete: Cascade)

  // Company data from Bolagsverket (populated in Story 4.2)
  org_number         String? @unique
  company_legal_name String?
  sni_code           String?

  // Story 5.1: Multi-tenancy fields
  company_logo      String?
  subscription_tier SubscriptionTier @default(TRIAL)
  trial_ends_at     DateTime?
  status            WorkspaceStatus  @default(ACTIVE)
  paused_at         DateTime?
  deleted_at        DateTime?

  // Story 5.5a: Trial workspaces remember which tier the user picked at signup
  // so getEffectiveLimits() can apply the right caps during the trial window.
  // NULL on existing rows; populated by Epic 4 onboarding flow on signup.
  // Cleared on trial→paid conversion (subscription_tier flips to picked tier).
  trial_picked_tier SubscriptionTier?

  // Story 5.12: signals user requested Enterprise during onboarding.
  // Trial limits are still capped at Team (trial_picked_tier='TEAM') to bound
  // COGS during the wait-for-sales window. Sales rep clears this column
  // when the Enterprise contract is signed and tier is flipped manually.
  enterprise_inquiry_at DateTime?

  // Story 5.4: Stripe billing
  stripe_customer_id           String?   @unique
  stripe_subscription_id       String?
  subscription_status          String? // Stripe status: active | past_due | canceled | unpaid
  current_period_end           DateTime?
  payment_grace_period_ends_at DateTime?

  // Story 5.13: idempotency lock for the daily expire-trials cron — prevents
  // re-sending the trial-ended email if the cron retries or runs twice.
  // Cleared implicitly: once trial converts (subscription_tier flips to
  // SOLO/TEAM and trial_ends_at goes NULL), the cron's WHERE clause stops
  // matching this row regardless of the column's value.
  trial_expired_notified_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  members         WorkspaceMember[]
  invitations     WorkspaceInvitation[]
  company_profile CompanyProfile?
  law_lists       LawList[]

  // Epic 6: Compliance workflow relations
  task_columns             TaskColumn[]
  tasks                    Task[]
  comments                 Comment[]
  files                    WorkspaceFile[]
  notifications            Notification[]
  notification_preferences NotificationPreference[]
  activity_logs            ActivityLog[]

  // Epic 3: AI Chat
  chat_messages ChatMessage[]

  // Story 14.27: Chat usage telemetry
  chat_usage_events ChatUsageEvent[]
  agent_decision_logs AgentDecisionLog[]

  // Story 14.22: Agent approval cards
  pending_agent_actions PendingAgentAction[]

  // Story 5.5c: AI token quota counter (one row per workspace)
  workspace_usage WorkspaceUsage?

  // Story 14.10: Change assessments
  change_assessments ChangeAssessment[]

  // Story 16.4: Law list generation
  // Story 25.0: dropped @default("pending") — with the wizard auto-fire removed,
  // new workspaces must land at NULL so getOnboardingState's null-check opens the
  // first-run modal. Existing rows keep whatever value they already have.
  law_list_generation_status     String?
  law_list_generation_error      String?
  law_list_generation_progress   Json?
  // Story 25.3 polish: set on every successful atomic claim in
  // generate-law-list/route.ts. Used by <ProgressStrip> to compute an
  // asymptotic % progress, and by B.4's done-state UI for "Klart på Xm Ys".
  law_list_generation_started_at DateTime?

  // Story 25.0 (Epic 25): First-run onboarding modal
  first_run_dismissed_at    DateTime?
  tutorial_fab_dismissed_at DateTime?
  first_run_tabs_viewed     Json?     @default("[]")

  // Epic 17: Document management
  workspace_documents WorkspaceDocument[]

  // Epic 21: Lagefterlevnadskontroll
  compliance_audit_cycles ComplianceAuditCycle[]

  // Epic 24: Import existing law list
  law_list_imports        LawListImport[]
  catalog_ingest_requests CatalogIngestRequest[]

  // Story 25.0 (Epic 25): First-run onboarding modal telemetry
  onboarding_events OnboardingEvent[]

  @@index([owner_id])
  @@index([org_number])
  @@index([status])
  @@map("workspaces")
}

model WorkspaceMember {
  id           String        @id @default(uuid())
  user_id      String
  workspace_id String
  role         WorkspaceRole @default(MEMBER)

  // Story 5.1: Invitation tracking
  invited_by String?
  invited_at DateTime?

  user      User      @relation("WorkspaceMemberUser", fields: [user_id], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  inviter   User?     @relation("WorkspaceMemberInviter", fields: [invited_by], references: [id])

  joined_at DateTime @default(now())

  @@unique([user_id, workspace_id])
  @@index([workspace_id])
  @@index([invited_by])
  @@map("workspace_members")
}

// ============================================================================
// WORKSPACE INVITATIONS - Story 10.3
// ============================================================================

model WorkspaceInvitation {
  id           String           @id @default(uuid())
  workspace_id String
  email        String
  role         WorkspaceRole    @default(MEMBER)
  token        String           @unique
  invited_by   String
  status       InvitationStatus @default(PENDING)
  expires_at   DateTime
  created_at   DateTime         @default(now())
  updated_at   DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  inviter   User      @relation("InvitationInviter", fields: [invited_by], references: [id])

  @@index([email])
  @@index([workspace_id])
  @@index([token])
  @@map("workspace_invitations")
}

// ============================================================================
// WORKSPACE PROFILE & LAW LISTS - Story 5.1
// ============================================================================

model CompanyProfile {
  id                 String  @id @default(uuid())
  workspace_id       String  @unique
  company_name       String
  sni_code           String?
  legal_form         String? // AB, HB, EF, etc.
  employee_count     Int?
  address            String?
  contextual_answers Json? // From onboarding questions

  // Story 14.4: Extended fields for compliance agent context
  org_number             String?
  organization_type      OrganizationType?
  industry_label         String?
  employee_count_range   EmployeeCountRange?
  activity_flags         Json? // { chemicals, construction, food, personalData, publicSector, heavyMachinery, minorEmployees, internationalOperations }
  certifications         String[]            @default([])
  compliance_maturity    ComplianceMaturity?
  has_compliance_officer Boolean             @default(false)
  profile_completeness   Int                 @default(0)
  last_onboarding_at     DateTime?

  // Story 14.4 phase 2: Extended fields
  municipality              String?
  website_url               String?
  founded_year              Int?
  has_collective_agreement  Boolean               @default(false)
  collective_agreement_name String?
  workforce_composition     WorkforceComposition?
  revenue_range             RevenueRange?

  // Story 15.1: BolagsAPI enrichment fields
  business_description String?
  tax_status           Json?
  foreign_owned        Boolean   @default(false)
  parent_company_name  String?
  parent_company_orgnr String?
  fi_regulated         Boolean   @default(false)
  active_status        String?
  ongoing_procedures   Json?
  registered_date      DateTime?
  data_source          String?
  last_enriched_at     DateTime?

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@map("company_profiles")
}

model LawList {
  id           String   @id @default(uuid())
  workspace_id String
  name         String // "Huvudlista", "Lager Malmö", "GDPR Focus"
  description  String?
  is_default   Boolean  @default(false)
  created_by   String?
  metadata     Json?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace Workspace      @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  creator   User?          @relation("LawListCreator", fields: [created_by], references: [id])
  items     LawListItem[]
  groups    LawListGroup[] // Story 4.13: Groups for organizing items

  // Epic 21: Lagefterlevnadskontroll
  compliance_audit_cycles ComplianceAuditCycle[]

  // Epic 24: Import existing law list — back-reference to the import this list was committed from (nullable; most lists are not import-derived)
  import_committed_from LawListImport?

  @@index([workspace_id])
  @@map("law_lists")
}

// Story 4.13: Groups for organizing documents within a law list
model LawListGroup {
  id          String   @id @default(uuid())
  law_list_id String
  name        String // "Arbetsmiljö", "GDPR", "Ekonomi"
  position    Float    @default(0) // For ordering groups (float allows inserting between)
  created_at  DateTime @default(now())

  law_list LawList       @relation(fields: [law_list_id], references: [id], onDelete: Cascade)
  items    LawListItem[]

  @@unique([law_list_id, name])
  @@index([law_list_id, position])
  @@map("law_list_groups")
}

model LawListItem {
  id          String @id @default(uuid())
  law_list_id String
  document_id String // FK to LegalDocument

  // User-editable fields
  commentary String? // AI-generated reason or user note
  status     LawListItemStatus   @default(NOT_STARTED)
  priority   LawListItemPriority @default(MEDIUM)
  notes      String?             @db.Text

  // Story 4.11: Position for drag-and-drop reordering (float allows inserting between items)
  position Float @default(0)

  // Story 4.12: Table view enhancements
  due_date    DateTime? // Review/compliance deadline
  assigned_to String? // FK to workspace member

  // Story 4.13: Grouping
  group_id String? // FK to LawListGroup (nullable - ungrouped items go to "Övrigt")

  // Epic 6: Compliance tracking fields
  compliance_status   ComplianceStatus @default(EJ_PABORJAD)
  responsible_user_id String? // Assigned responsible person
  business_context    String?          @db.Text // Why this law matters to the business
  ai_commentary       String?          @db.Text // AI-generated analysis
  category            String? // Custom categorization

  // Business context update attribution (mirrors compliance_narrative pattern)
  business_context_updated_at DateTime? // Last update timestamp
  business_context_updated_by String? // User ID who last updated

  // Story 21.22: Compliance narrative — "Hur efterlever vi kraven?" first-class
  // top-level field on the law-list-item modal (renamed from compliance_actions).
  compliance_narrative            String?   @db.Text
  compliance_narrative_updated_at DateTime?
  compliance_narrative_updated_by String?

  // Metadata
  source     LawListItemSource @default(MANUAL)
  added_by   String?
  added_at   DateTime          @default(now())
  updated_at DateTime          @updatedAt

  // Change tracking — onboarding floor (set when law is first added to list).
  // Changes detected before this timestamp are considered pre-existing.
  // Individual assessment tracking uses ChangeAssessment records, not this field.
  // TODO: Rename to changes_tracked_from for clarity.
  last_change_acknowledged_at DateTime?
  last_change_acknowledged_by String?

  law_list         LawList       @relation(fields: [law_list_id], references: [id], onDelete: Cascade)
  document         LegalDocument @relation(fields: [document_id], references: [id])
  adder            User?         @relation("LawListItemAdder", fields: [added_by], references: [id])
  assignee         User?         @relation("LawListItemAssignee", fields: [assigned_to], references: [id])
  responsible_user User?         @relation("LawListItemResponsible", fields: [responsible_user_id], references: [id])
  group            LawListGroup? @relation(fields: [group_id], references: [id], onDelete: SetNull) // Story 4.13

  // Epic 6: Relations to tasks, comments, files
  task_links TaskListItemLink[]
  comments   Comment[]
  file_links FileListItemLink[]

  // Story 14.10: Change assessments and compliance status logs
  change_assessments     ChangeAssessment[]
  compliance_status_logs ComplianceStatusLog[]

  // Epic 17: Document management
  workspace_document_links WorkspaceDocumentListItemLink[]

  // Story 17.16: Kravpunkter (structured compliance checklist)
  requirements LawListItemRequirement[]

  // Epic 21: Lagefterlevnadskontroll
  compliance_audit_items ComplianceAuditItem[]
  compliance_findings    ComplianceFinding[]   @relation("FindingLawListItem")

  @@unique([law_list_id, document_id])
  @@index([law_list_id])
  @@index([document_id])
  @@index([status])
  @@index([law_list_id, position]) // Story 4.11: Fast ordered queries
  @@index([group_id]) // Story 4.13: Fast group queries
  @@index([compliance_status]) // Epic 6: Fast compliance queries
  @@index([responsible_user_id]) // Epic 6: Fast responsible person queries
  @@map("law_list_items")
}

// ============================================================================
// STORY 17.16: KRAVPUNKTER — Structured compliance checklist per LawListItem
// ============================================================================

model LawListItemRequirement {
  id                  String   @id @default(uuid())
  list_item_id        String
  text                String   @db.Text
  comment             String?  @db.Text
  is_fulfilled        Boolean  @default(false)
  bevis_required      Boolean  @default(false)
  position            Float    @default(0) // Float + no unique constraint → fractional midpoint reorder (mirrors LawListItem.position)
  created_by          String
  responsible_user_id String? // Story 20.1: per-krav assignee override; null → inherit from parent list item's responsible_user_id
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  list_item        LawListItem               @relation(fields: [list_item_id], references: [id], onDelete: Cascade)
  creator          User                      @relation("RequirementCreator", fields: [created_by], references: [id])
  responsible_user User?                     @relation("RequirementResponsible", fields: [responsible_user_id], references: [id], onDelete: SetNull)
  evidence_links   RequirementEvidenceLink[]

  // Epic 21: Lagefterlevnadskontroll
  compliance_findings ComplianceFinding[] @relation("FindingRequirement")

  @@index([list_item_id, position])
  @@index([created_by])
  @@index([responsible_user_id])
  @@map("law_list_item_requirements")
}

model RequirementEvidenceLink {
  id                    String   @id @default(uuid())
  requirement_id        String
  file_id               String? // FK → WorkspaceFile (nullable — XOR with workspace_document_id)
  workspace_document_id String? // FK → WorkspaceDocument (nullable — XOR with file_id, prefixed per Epic 17 collision rule)
  linked_at             DateTime @default(now())
  linked_by             String

  requirement        LawListItemRequirement @relation(fields: [requirement_id], references: [id], onDelete: Cascade)
  file               WorkspaceFile?         @relation(fields: [file_id], references: [id], onDelete: Cascade)
  workspace_document WorkspaceDocument?     @relation(fields: [workspace_document_id], references: [id], onDelete: Cascade)
  linker             User                   @relation("RequirementEvidenceLinkUser", fields: [linked_by], references: [id])

  // XOR enforced at application layer via Zod (.refine). Unique constraints prevent duplicate links.
  @@unique([requirement_id, file_id])
  @@unique([requirement_id, workspace_document_id])
  @@index([requirement_id])
  @@index([file_id])
  @@index([workspace_document_id])
  @@map("requirement_evidence_links")
}

// ============================================================================
// LEGAL CONTENT MODELS - Epic 1: Story 1.5
// ============================================================================

model LegalDocument {
  id                     String                       @id @default(uuid())
  content_type           ContentType
  document_number        String                       @unique // "SFS 1977:1160", "NJA 2023 s. 45"
  title                  String
  slug                   String                       @unique
  summary                String?                      @db.Text // Summering — neutral description of what the law regulates
  kommentar              String?                      @db.Text // Kommentar — actionable compliance commentary ("Vi ska..." voice)
  applicability_hint     String?                      @db.Text // LLM-optimized: "Gäller [who]. [Threshold]. Reglerar [what]."
  summering_generated_by String? // Model identifier for summary generation (e.g., "claude-opus-4-6")
  kommentar_generated_by String? // Model identifier for kommentar generation (e.g., "claude-opus-4-6")
  full_text              String?                      @db.Text // Plain text for RAG, search, embeddings
  html_content           String?                      @db.Text // SSOT - LLM-generated or API-sourced HTML for rendering
  markdown_content       String?                      @db.Text // Derived from HTML - for Chat/RAG context
  json_content           Json? // Derived from HTML - for structured queries
  effective_date         DateTime?
  publication_date       DateTime?
  status                 DocumentStatus               @default(ACTIVE)
  // Story 2.32: Subtype within SFS_LAW / SFS_AMENDMENT — distinguishes lag, förordning,
  // kungörelse. Populated at ingest via lib/sfs/instrument.ts (title classifier).
  // Defaults to OTHER for non-SFS rows and ambiguous SFS titles.
  sfs_instrument         SfsInstrument                @default(OTHER)
  source_url             String
  metadata               Json? // Type-specific metadata storage (includes filbilaga if present)
  search_vector          Unsupported("tsvector")? // Full-text search
  embedding              Unsupported("vector(1536)")? // Semantic search
  created_at             DateTime                     @default(now())
  updated_at             DateTime                     @updatedAt

  // Story 8.16: Change tracking fields — SSOT for latest legal change
  last_change_type ChangeType? // What happened most recently (AMENDMENT, REPEAL, etc.)
  last_change_ref  String? // Causing document ref (e.g., "SFS 2026:145")
  last_change_at   DateTime? // When the change was detected (distinct from updated_at)

  // Relations
  court_case          CourtCase?
  eu_document         EuDocument?
  source_references   CrossReference[]  @relation("SourceDocument")
  target_references   CrossReference[]  @relation("TargetDocument")
  base_amendments     Amendment[]       @relation("BaseDocument")
  amending_amendments Amendment[]       @relation("AmendingDocument")
  subjects            DocumentSubject[]
  versions            DocumentVersion[]
  change_events       ChangeEvent[]
  law_sections        LawSection[] // Story 2.13: Parsed sections for historical versions
  law_list_items      LawListItem[] // Story 5.1: Law list items referencing this document
  legislative_refs    LegislativeRef[] // Story 2.29: Extracted prop/bet/rskr references
  visits              DocumentVisit? // Story P.1: Visit tracking for cache optimization
  template_items      TemplateItem[] // Story 12.2: Template items referencing this document

  // Epic 24: Import existing law list
  import_rows_matched        LawListImportRow[]
  catalog_requests_fulfilled CatalogIngestRequest[]

  @@index([document_number])
  @@index([slug])
  @@index([content_type])
  @@index([status])
  @@index([search_vector])
  // Story 2.19: Composite indexes for optimized catalogue queries
  @@index([content_type, status, effective_date(sort: Desc)], name: "idx_browse_composite")
  @@index([content_type, effective_date(sort: Desc)], name: "idx_browse_content_date")
  @@index([publication_date(sort: Desc)], name: "idx_publication_date")
  @@index([last_change_type], name: "idx_last_change_type") // Story 8.16: Filter/sort by change type
  @@index([sfs_instrument], name: "idx_sfs_instrument") // Story 2.32: Lag vs förordning filter
  @@map("legal_documents")
}

// ============================================================================
// DOCUMENT VISITS TRACKING - Story P.1: Performance Optimization
// ============================================================================

model DocumentVisit {
  document_id  String   @id // TEXT to match legal_documents.id type
  visit_count  Int      @default(1)
  last_visited DateTime @default(now())
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // Relations
  document LegalDocument @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@index([visit_count(sort: Desc)]) // For finding most visited
  @@index([last_visited(sort: Desc)]) // For recent activity
  @@map("document_visits")
}

enum ContentType {
  SFS_LAW
  SFS_AMENDMENT // Story 2.13: Amendment documents (ändringsförfattningar)
  COURT_CASE_AD
  COURT_CASE_HD
  COURT_CASE_HOVR
  COURT_CASE_HFD
  COURT_CASE_MOD
  COURT_CASE_MIG
  EU_REGULATION
  EU_DIRECTIVE
  AGENCY_REGULATION // Story 12.1: Agency regulation stubs (AFS, BFS, NFS, etc.)
}

enum DocumentStatus {
  ACTIVE
  REPEALED
  DRAFT
  ARCHIVED
}

// Story 2.32: SFS instrument subtype — distinguishes lag (parliament), förordning
// (government regulation), and kungörelse from each other within SFS_LAW/SFS_AMENDMENT.
// Populated at ingest by lib/sfs/instrument.ts; OTHER covers non-SFS rows and
// low-confidence title matches.
enum SfsInstrument {
  LAG
  FORORDNING
  KUNGORELSE
  OTHER
}

// Story 2.29: Legislative reference types (prop, bet, rskr, etc.)
enum LegislativeRefType {
  PROP // Proposition (government bill)
  BET // Betänkande (committee report)
  RSKR // Riksdagsskrivelse (parliamentary decision)
  SOU // Statens offentliga utredningar
  DS // Departementsserien
}

// Story 2.29: Extracted legislative references from amendment footnotes
// Enables queries like "all amendments referencing Prop. 2024/25:59"
model LegislativeRef {
  id                String             @id @default(uuid())
  legal_document_id String
  ref_type          LegislativeRefType
  reference         String // Full ref: "Prop. 2024/25:59"
  year              String // Parliamentary year: "2024/25"
  number            String // Document number: "59" or "JuU22"
  created_at        DateTime           @default(now())

  legal_document LegalDocument @relation(fields: [legal_document_id], references: [id], onDelete: Cascade)

  @@unique([legal_document_id, ref_type, reference])
  @@index([reference])
  @@index([ref_type, year])
  @@index([legal_document_id])
