# Supabase Database Connection
# ============================================================================
# IMPORTANT: Supabase Pooler Configuration
#
# - Port 6543: Transaction mode (pgbouncer) - Use for app queries
# - Port 5432: Session mode - Use for Prisma migrations (db push, migrate)
#
# Both use the POOLER hostname: aws-1-eu-north-1.pooler.supabase.com
# ============================================================================

# Transaction mode (Port 6543 with pgbouncer) - Used for app queries
# pool_timeout=30 increases from default 10s to handle Vercel build concurrency
# connection_limit MUST be >1: Vercel Fluid Compute serves many concurrent
# requests per instance and they all share this pool — limit=1 serializes every
# query and causes "Timed out fetching a new connection" under load (2026-07-14)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-1-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10&pool_timeout=30"

# Session mode pooler (Port 5432) - Required for Prisma migrations
DIRECT_URL="postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-1-eu-north-1.pooler.supabase.com:5432/postgres"

# Node Environment
NODE_ENV="development"

# Supabase CLI Access Token
# Get from: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=""

# Supabase Auth
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# NextAuth.js
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Field encryption (Epic 7 — Employee personnummer, AES-256-GCM)
# 32-byte key, base64-encoded. Generate: openssl rand -base64 32
# MUST be set in every environment before any personnummer is written —
# encryptField() fails closed (throws) if missing/malformed, so plaintext is
# never persisted. Rotating this key invalidates existing ciphertext.
ENCRYPTION_KEY=""

# Google Analytics 4 (optional — GA4 only mounts when set + user consents)
# Get measurement ID from analytics.google.com → property → admin → data streams.
# Leave empty in dev/preview to avoid polluting the production property.
NEXT_PUBLIC_GA_ID=""

# Google Ads conversion tracking (optional — the tag only mounts when the
# account id is set AND the user grants the "marketing" consent category).
# Account id: Google Ads → Goals → Conversions → tag setup (format "AW-1234567890").
# Signup label: the conversion-action label shown in that same tag setup.
NEXT_PUBLIC_GOOGLE_ADS_ID=""
NEXT_PUBLIC_GOOGLE_ADS_SIGNUP_LABEL=""

# Sentry Error Tracking
# ============================================================================
# DSN (public - safe to expose to client)
# Get from: https://YOUR_ORG.sentry.io/settings/projects/YOUR_PROJECT/keys/
NEXT_PUBLIC_SENTRY_DSN=""

# Sentry Organization and Project (for source map uploads)
# Get org slug from: https://sentry.io/settings/
SENTRY_ORG=""
SENTRY_PROJECT=""

# Auth Token (for source map uploads in CI)
# Generate from: https://sentry.io/settings/account/api/auth-tokens/
# Required scopes: project:releases, org:read
SENTRY_AUTH_TOKEN=""

# Cohere Rerank (optional — improves search relevance, degrades gracefully without it)
COHERE_API_KEY=""

# BolagsAPI (Epic 15 — optional, degrades gracefully without it)
# Get API key from: https://bolagsapi.se
BOLAGSAPI_API_KEY=""

# Admin Backoffice (Epic 11)
# Comma-separated list of admin email addresses
ADMIN_EMAILS=admin@laglig.se
# Generate secret: openssl rand -base64 32
ADMIN_JWT_SECRET=""

# Vercel Cron auth (shared by all /api/cron/* routes).
# The bearer Vercel Cron sends on scheduled invocations. MUST be set in
# production — if unset, the cron auth guard short-circuits and the endpoints
# (some of which write data / send email) become publicly callable. Generate:
# openssl rand -base64 32
CRON_SECRET=""

# Unit Economics (Story 5.10)
# Recipient of the weekly unit-economics founder report
# (app/api/cron/unit-economics-report). Falls back to CRON_NOTIFICATION_EMAIL
# if unset; report no-ops if neither is set.
FOUNDER_EMAIL=""
